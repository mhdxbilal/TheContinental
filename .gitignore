# ─── Gradle build outputs ────────────────────────────────────────────
.gradle/
build/
app/build/

# ─── Android Studio / IntelliJ ───────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
local.properties
captures/
.externalNativeBuild/
.cxx/

# ─── macOS ────────────────────────────────────────────────────────────
.DS_Store

# ─── Windows ──────────────────────────────────────────────────────────
Thumbs.db

# ─── Signing keystores — NEVER commit these ──────────────────────────
*.jks
*.keystore
keystore.properties

# ─── Keep the Gradle wrapper (needed by CI to bootstrap without a
#     pre-installed Gradle binary on the runner) ─────────────────────
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties
!gradlew
!gradlew.bat
